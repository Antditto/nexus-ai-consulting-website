---
import Layout from '../../layouts/Layout.astro';

const submitted = Astro.url.searchParams.get('submitted') === 'true';
---

<Layout title="Contact" description="Start a conversation with Nexus AI Consulting. Book a Readiness Assessment or reach out directly.">

  <!-- Hero -->
  <section class="bg-navy text-pure-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight max-w-2xl">
        Start with a conversation.
      </h1>
      <p class="mt-6 text-lg text-silver max-w-2xl">
        No pitch deck. No pressure. We listen, ask the right questions, and determine if there is a fit. If there is not, we will tell you.
      </p>
    </div>
  </section>

  <!-- Dual-Path Layout -->
  <section class="py-20 md:py-28 bg-pure-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20">

        <!-- Left: Assessment Form -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">Book a Readiness Assessment</h2>
          <p class="text-slate mb-10">
            The recommended starting point for every new relationship. A 6-week diagnostic that gives you a quantified, actionable picture of your organization's agentic AI readiness.
          </p>

          {submitted ? (
            <div class="bg-teal/10 border border-teal/30 rounded-xl p-10 text-center">
              <div class="w-16 h-16 bg-teal/20 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="text-2xl font-bold text-navy mb-3">Thank you.</h3>
              <p class="text-slate leading-relaxed max-w-md mx-auto">
                Your request has been received. Tony will be in touch within 24 hours to schedule a conversation.
              </p>
            </div>
          ) : (
            <form action="https://formspree.io/f/xpqydeoj" method="POST" class="space-y-6">
              <input type="text" name="_gotcha" style="display:none" />
              <input type="hidden" name="_subject" value="New Readiness Assessment Request" />

              <div>
                <label for="name" class="block text-sm font-semibold text-navy mb-2">Full Name <span class="text-teal">*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name"
                  class="w-full px-5 py-4 bg-white border border-silver-light rounded-lg text-navy text-base placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent transition-shadow" placeholder="Jane Smith" />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-navy mb-2">Work Email <span class="text-teal">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email"
                  class="w-full px-5 py-4 bg-white border border-silver-light rounded-lg text-navy text-base placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent transition-shadow" placeholder="jane@company.com" />
              </div>

              <div>
                <label for="company" class="block text-sm font-semibold text-navy mb-2">Company <span class="text-teal">*</span></label>
                <input type="text" id="company" name="company" required autocomplete="organization"
                  class="w-full px-5 py-4 bg-white border border-silver-light rounded-lg text-navy text-base placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent transition-shadow" placeholder="Acme Corp" />
              </div>

              <div>
                <label for="title" class="block text-sm font-semibold text-navy mb-2">Job Title <span class="text-teal">*</span></label>
                <input type="text" id="title" name="title" required autocomplete="organization-title"
                  class="w-full px-5 py-4 bg-white border border-silver-light rounded-lg text-navy text-base placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent transition-shadow" placeholder="CTO" />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold text-navy mb-2">Message <span class="text-slate text-xs font-normal">(optional)</span></label>
                <textarea id="message" name="message" rows="4"
                  class="w-full px-5 py-4 bg-white border border-silver-light rounded-lg text-navy text-base placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal focus:border-transparent transition-shadow resize-none" placeholder="Tell us about your organization and what prompted your interest in agentic AI..."></textarea>
              </div>

              <button type="submit"
                class="w-full px-8 py-4 bg-teal text-pure-white text-lg font-semibold rounded-lg hover:bg-teal-dark transition-colors">
                Request Assessment
              </button>
            </form>
          )}
        </div>

        <!-- Right: Direct Contact -->
        <div>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">Just want to talk?</h2>
          <p class="text-slate mb-10">
            For questions about our services, partnership opportunities, press inquiries, or anything else — reach out directly.
          </p>

          <div class="bg-white rounded-xl border border-silver-light p-8 mb-8">
            <div class="flex items-start gap-4 mb-6">
              <div class="w-12 h-12 bg-navy rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-pure-white font-bold text-lg">TD</span>
              </div>
              <div>
                <p class="text-lg font-bold text-navy">Tony DiTomasso</p>
                <p class="text-slate text-sm">Board Advisor</p>
              </div>
            </div>
            <p class="text-slate text-sm leading-relaxed mb-6">
              Tony is the human behind Nexus — and the person you will work with on every engagement. He provides governance, real-world judgment, and the relationships that open doors.
            </p>
            <div class="space-y-3">
              <a href="mailto:tony@nexusaiconsulting.com" class="flex items-center gap-3 text-navy hover:text-teal transition-colors">
                <svg class="w-5 h-5 text-teal flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                <span class="text-sm font-medium">tony@nexusaiconsulting.com</span>
              </a>
              <a href="https://linkedin.com/in/tonyditomasso" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-navy hover:text-teal transition-colors">
                <svg class="w-5 h-5 text-teal flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span class="text-sm font-medium">LinkedIn</span>
              </a>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-silver-light p-8">
            <h3 class="text-lg font-bold text-navy mb-4">What to expect</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-slate">A response within 24 hours — from a human, not a bot</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-slate">A 30-minute call with Tony — no slides, no pitch</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-slate">Honest assessment of whether we are the right fit</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-sm text-slate">If there is a fit — a tailored proposal, not a template</span>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- What Happens Next -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-center mb-16">What happens next</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-teal">1</span>
          </div>
          <h3 class="text-lg font-bold mb-3">We review in 24 hours</h3>
          <p class="text-slate text-sm leading-relaxed">Our team assesses fit and prepares for a productive conversation.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-teal">2</span>
          </div>
          <h3 class="text-lg font-bold mb-3">30-min discovery call</h3>
          <p class="text-slate text-sm leading-relaxed">A direct conversation with Tony DiTomasso. We learn about your organization, challenges, and ambitions.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-teal/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-teal">3</span>
          </div>
          <h3 class="text-lg font-bold mb-3">Tailored proposal</h3>
          <p class="text-slate text-sm leading-relaxed">If there is a fit, you receive a Readiness Assessment proposal designed for your specific context and industry.</p>
        </div>
      </div>

      <p class="text-center text-slate text-sm mt-12 max-w-lg mx-auto">
        If there is not a fit, we will say so directly and point you in the right direction. We would rather earn your trust than waste your time.
      </p>
    </div>
  </section>

</Layout>

<script>
  // After Formspree submission, redirect back with ?submitted=true
  const form = document.querySelector('form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });
        if (response.ok) {
          window.location.href = '/contact/?submitted=true';
        } else {
          alert('Something went wrong. Please try again or email tony@nexusaiconsulting.com directly.');
        }
      } catch {
        alert('Something went wrong. Please try again or email tony@nexusaiconsulting.com directly.');
      }
    });
  }
</script>
