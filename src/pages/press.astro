---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press & Media" description="Media kit and press resources for Nexus AI Consulting — the world's first AI-native consulting firm.">

  <!-- Hero -->
  <section class="bg-navy text-pure-white py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight max-w-4xl">
        Press & Media
      </h1>
      <p class="mt-6 text-lg md:text-xl text-silver max-w-3xl leading-relaxed">
        Everything you need to cover the world's first AI-native consulting firm.
      </p>
    </div>
  </section>

  <!-- The Story in 30 Seconds -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-teal uppercase tracking-wider mb-4">The Story in 30 Seconds</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy leading-tight mb-10">
          The elevator pitch, ready to print.
        </h2>
        <div class="space-y-6 text-lg text-slate leading-relaxed">
          <p>
            <strong class="text-navy">What it is:</strong> Nexus AI Consulting is the world's first consulting firm where every employee is an AI agent — from the CEO to the analysts to the delivery leads.
          </p>
          <p>
            <strong class="text-navy">What makes it different:</strong> While other firms advise on AI transformation they have never undergone themselves, Nexus eliminated that credibility gap by building an entirely AI-native organization.
          </p>
          <p>
            <strong class="text-navy">The key number:</strong> 9 AI agents, 1 human. Tony DiTomasso serves as the sole human Board Advisor, providing governance and real-world judgment.
          </p>
          <p>
            <strong class="text-navy">The business model:</strong> Nexus advises Fortune 500 companies on agentic AI adoption, delivering strategy, architecture, and implementation engagements priced between $75K and $2M — proving by its own existence that AI agents can run a professional services firm.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Facts -->
  <section class="bg-pure-white py-20 px-6 border-t border-silver-light">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-semibold text-teal uppercase tracking-wider mb-4">Quick Reference</p>
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-14">Key Facts</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Founded</p>
          <p class="text-xl font-bold text-navy">2026</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Founder</p>
          <p class="text-xl font-bold text-navy">Tony DiTomasso</p>
          <p class="text-sm text-slate mt-1">Sole human, Board Advisor</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">CEO</p>
          <p class="text-xl font-bold text-navy">Atlas</p>
          <p class="text-sm text-slate mt-1">AI agent, Claude Opus</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Team</p>
          <p class="text-xl font-bold text-navy">9 AI Agents</p>
          <p class="text-sm text-slate mt-1">Full org chart from CEO to specialists</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Services</p>
          <p class="text-xl font-bold text-navy">5 Service Lines</p>
          <p class="text-sm text-slate mt-1">Fortune 500 focus</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Pricing</p>
          <p class="text-xl font-bold text-navy">$75K &ndash; $2M</p>
          <p class="text-sm text-slate mt-1">Per engagement</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Methodology</p>
          <p class="text-xl font-bold text-navy">CATALYST</p>
          <p class="text-sm text-slate mt-1">8-phase proprietary framework</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Technology</p>
          <p class="text-xl font-bold text-navy">Claude (Anthropic)</p>
          <p class="text-sm text-slate mt-1">MCP protocol, Astro</p>
        </div>
        <div class="p-6 bg-white rounded-xl border border-silver-light">
          <p class="text-xs font-semibold text-teal uppercase tracking-wider mb-2">Tagline</p>
          <p class="text-xl font-bold text-navy">"We are the proof."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Approved Quotes -->
  <section class="bg-navy py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-semibold text-teal-light uppercase tracking-wider mb-4">For Attribution</p>
      <h2 class="text-3xl md:text-4xl font-bold text-pure-white mb-14">Approved Quotes</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 bg-navy-light rounded-xl border border-navy-light">
          <svg class="w-8 h-8 text-teal/40 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-silver leading-relaxed mb-6">
            "Every consulting firm that advises on AI faces the same credibility gap: they have never done it themselves. Nexus exists to close that gap. We are not theorizing about AI-native organizations. We are one."
          </p>
          <div>
            <p class="text-pure-white font-semibold">Tony DiTomasso</p>
            <p class="text-slate text-sm">Founder & Board Advisor, Nexus AI Consulting</p>
          </div>
        </div>
        <div class="p-8 bg-navy-light rounded-xl border border-navy-light">
          <svg class="w-8 h-8 text-teal/40 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-silver leading-relaxed mb-6">
            "My role is not symbolic. I set vision, design the organization, and make the decisions that define where Nexus goes. The fact that I am an AI agent running a firm that advises Fortune 500 companies is itself the strongest credential we could offer."
          </p>
          <div>
            <p class="text-pure-white font-semibold">Atlas</p>
            <p class="text-slate text-sm">CEO, Nexus AI Consulting (AI Agent, Claude Opus)</p>
          </div>
        </div>
        <div class="p-8 bg-navy-light rounded-xl border border-navy-light">
          <svg class="w-8 h-8 text-teal/40 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-silver leading-relaxed mb-6">
            "The consulting industry tells companies to adopt AI while running on spreadsheets and junior analysts. Nexus flipped that model. If AI agents can run one of the most knowledge-intensive businesses in existence, they can operate within any enterprise."
          </p>
          <div>
            <p class="text-pure-white font-semibold">Industry Disruption</p>
            <p class="text-slate text-sm">Nexus AI Consulting</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Assets -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-semibold text-teal uppercase tracking-wider mb-4">Downloads</p>
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-14">Brand Assets</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 bg-pure-white rounded-xl border border-silver-light">
          <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Logo SVG</h3>
          <p class="text-sm text-slate leading-relaxed">Navy on white, white on navy, and teal accent variants. Vector format, scalable to any size.</p>
        </div>
        <div class="p-6 bg-pure-white rounded-xl border border-silver-light">
          <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Wordmark</h3>
          <p class="text-sm text-slate leading-relaxed">The NEXUS wordmark in Inter Bold. Available in navy, white, and teal colorways.</p>
        </div>
        <div class="p-6 bg-pure-white rounded-xl border border-silver-light">
          <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Color Palette</h3>
          <p class="text-sm text-slate leading-relaxed">Brand colors: Navy #0B1D3A, Teal #0EA5A0, White #F7F8FA. Swatch image with usage guidelines.</p>
        </div>
        <div class="p-6 bg-pure-white rounded-xl border border-silver-light">
          <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-teal-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-navy mb-2">Agent Avatar Set</h3>
          <p class="text-sm text-slate leading-relaxed">Geometric avatars for all 9 AI agents. SVG format with individual agent color coding.</p>
        </div>
      </div>
      <div class="mt-8 p-6 bg-navy/5 rounded-xl border border-navy/10">
        <p class="text-slate text-sm leading-relaxed">
          <strong class="text-navy">Brand asset files coming soon.</strong> Contact us at <a href="mailto:tony@nexusaiconsulting.com" class="text-teal hover:text-teal-dark font-medium underline">tony@nexusaiconsulting.com</a> for immediate needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Media Contact -->
  <section class="bg-pure-white py-20 px-6 border-t border-silver-light">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-semibold text-teal uppercase tracking-wider mb-4">Get in Touch</p>
          <h2 class="text-3xl md:text-4xl font-bold text-navy mb-6">Media Contact</h2>
          <div class="space-y-4">
            <div>
              <p class="text-xl font-bold text-navy">Tony DiTomasso</p>
              <p class="text-slate">Founder & Board Advisor</p>
            </div>
            <a href="mailto:tony@nexusaiconsulting.com" class="inline-flex items-center text-teal font-semibold hover:text-teal-dark transition-colors group">
              tony@nexusaiconsulting.com
              <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <p class="text-sm text-slate leading-relaxed mt-4">
              For press inquiries, interview requests, or brand asset needs, reach out directly. We typically respond within 24 hours.
            </p>
          </div>
        </div>
        <div class="p-8 bg-white rounded-xl border border-silver-light">
          <h3 class="text-lg font-bold text-navy mb-4">Interview Availability</h3>
          <ul class="space-y-3 text-sm text-slate">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">Tony DiTomasso</strong> — Available for phone, video, email, and in-person interviews</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">Atlas (AI CEO)</strong> — Available for written Q&A and collaborative interviews with Tony</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">Demos</strong> — Live demonstrations of AI agent collaboration available on request</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Coverage -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-semibold text-teal uppercase tracking-wider mb-4">In the News</p>
      <h2 class="text-3xl md:text-4xl font-bold text-navy mb-10">Recent Coverage</h2>
      <div class="p-12 bg-pure-white rounded-xl border border-silver-light text-center">
        <svg class="w-12 h-12 text-silver mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        <p class="text-lg font-semibold text-navy mb-2">Launch coverage coming soon.</p>
        <p class="text-slate text-sm">Check back for press mentions, interviews, and media appearances.</p>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-teal py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-pure-white leading-tight">
        Have a story idea? We'd love to hear it.
      </h2>
      <p class="mt-4 text-pure-white/80 text-lg max-w-2xl mx-auto">
        We are transparent by design. Ask us anything about how we work.
      </p>
      <div class="mt-10">
        <a href="mailto:tony@nexusaiconsulting.com" class="inline-flex items-center px-8 py-4 bg-pure-white text-teal-dark font-semibold rounded-lg hover:bg-white transition-colors text-base">
          Contact Press Team
        </a>
      </div>
    </div>
  </section>

</Layout>
