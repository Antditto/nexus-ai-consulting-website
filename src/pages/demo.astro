  // Maturity level descriptions
  const MATURITY_LEVELS = {
    exploring: {
      label: 'Exploring',
      range: [0, 35],
      color: '#E53E3E',
      badgeColor: 'bg-red-500/20 text-red-300',
      desc: 'Your organization is in the early stages of agentic AI awareness. Interest exists but foundational capabilities — executive sponsorship, data infrastructure, governance — need development before pilot programs are feasible. This is a common starting point for organizations that recognize the opportunity but have not yet invested in readiness.',
    },
    experimenting: {
      label: 'Experimenting',
      range: [36, 55],
      color: '#DD6B20',
      badgeColor: 'bg-orange-500/20 text-orange-300',
      desc: 'Your organization has foundational elements in place and may be running initial AI experiments. There are meaningful gaps to close, but the trajectory is positive. With targeted investments in the weakest dimensions, you could be pilot-ready within 6-12 months.',
    },
    operationalizing: {
      label: 'Operationalizing',
      range: [56, 75],
      color: '#0EA5A0',
      badgeColor: 'bg-teal/20 text-teal-light',
      desc: 'Your organization has solid foundations across most dimensions and is well-positioned to move from experimentation to production-grade agentic deployment. The focus should be on closing remaining gaps and designing enterprise architecture that can scale.',
    },
    transforming: {
      label: 'Transforming',
      range: [76, 100],
      color: '#38A169',
      badgeColor: 'bg-green-500/20 text-green-300',
      desc: 'Your organization has mature capabilities across the board and is ready for enterprise-scale agentic AI deployment. The focus should be on advanced multi-agent orchestration, competitive differentiation, and building the operating model that sustains long-term agentic operations.',
    },
  };

  // =========================================================================
  // State
  // =========================================================================
  let currentStep = 1;
  let currentQuestion = 0;
  const answers: Record<string, number> = {};

  // =========================================================================
  // Navigation
  // =========================================================================
  function showStep(step: number) {
    document.querySelectorAll('.step-panel').forEach((el) => {
      (el as HTMLElement).classList.add('hidden');
    });
    const panel = document.getElementById(`step-${step}`);
    if (panel) {
      panel.classList.remove('hidden');
      // Re-trigger animation
      panel.style.animation = 'none';
      panel.offsetHeight; // force reflow
      panel.style.animation = '';
    }

    // Update progress dots
    document.querySelectorAll('.step-dot').forEach((dot) => {
      const dotStep = parseInt((dot as HTMLElement).dataset.step || '0');
      const circle = dot.querySelector('span:first-child') as HTMLElement;
      const label = dot.querySelector('span:last-child') as HTMLElement;

      if (dotStep <= step) {
        circle.className = 'w-8 h-8 rounded-full bg-teal text-pure-white flex items-center justify-center text-xs font-bold';
        (dot as HTMLElement).className = dot.className.replace(/text-slate/g, 'text-teal');
        if (!dot.className.includes('text-teal')) {
          (dot as HTMLElement).classList.add('text-teal');
        }
      } else {
        circle.className = 'w-8 h-8 rounded-full bg-silver-light text-slate flex items-center justify-center text-xs font-bold';
        (dot as HTMLElement).className = dot.className.replace(/text-teal/g, 'text-slate');
      }
    });

    currentStep = step;
  }

  function renderQuestion(index: number) {
    const q = QUESTIONS[index];
    const container = document.getElementById('question-container');
    if (!container) return;

    const selectedScore = answers[q.id] || 0;

    container.innerHTML = `
      <div class="mb-6 flex items-center justify-between">
        <span class="question-counter text-xs font-bold text-teal uppercase tracking-wider">Question ${index + 1} of ${QUESTIONS.length}</span>
        <span class="text-xs text-slate font-medium">${q.dimension}</span>
      </div>
      <h3 class="text-lg font-bold text-navy mb-6">${q.question}</h3>
      <div class="space-y-3">
        ${q.options
          .map(
            (opt, i) => `
          <div class="option-card p-4 rounded-lg border border-silver-light ${selectedScore === opt.score ? 'selected' : ''}" data-score="${opt.score}" data-question="${q.id}">
            <div class="flex items-start gap-3">
              <div class="option-radio mt-0.5 w-5 h-5 rounded-full border-2 ${selectedScore === opt.score ? 'bg-teal border-teal' : 'border-silver'} flex items-center justify-center flex-shrink-0">
                ${selectedScore === opt.score ? '<div class="w-2 h-2 rounded-full bg-pure-white"></div>' : ''}
              </div>
              <div>
                <p class="text-sm font-semibold text-navy">${opt.text}</p>
                <p class="text-xs text-slate mt-1">${opt.desc}</p>
              </div>
            </div>
          </div>
        `
          )
          .join('')}
      </div>
    `;

    // Attach click handlers
    container.querySelectorAll('.option-card').forEach((card) => {
      card.addEventListener('click', () => {
        const score = parseInt((card as HTMLElement).dataset.score || '0');
        const questionId = (card as HTMLElement).dataset.question || '';
        answers[questionId] = score;
        renderQuestion(index); // re-render to show selection
      });
    });

    // Update nav buttons
    const prevBtn = document.getElementById('btn-prev-q') as HTMLButtonElement;
    const nextBtn = document.getElementById('btn-next-q') as HTMLButtonElement;

    if (prevBtn) {
      prevBtn.style.visibility = index === 0 ? 'hidden' : 'visible';
    }

    if (nextBtn) {
      nextBtn.textContent = index === QUESTIONS.length - 1 ? 'See Results' : 'Next \u2192';
    }
  }

  // =========================================================================
  // Score Calculation
  // =========================================================================
  function calculateScore(): number {
    let total = 0;
    let count = 0;
    QUESTIONS.forEach((q) => {
      if (answers[q.id]) {
        total += answers[q.id];
        count++;
      }
    });
    if (count === 0) return 0;
    // Scale from 1-4 range to 0-100
    const avgScore = total / count; // 1-4
    return Math.round(((avgScore - 1) / 3) * 100);
  }

  function getDimensionScore(questionId: string): number {
    const raw = answers[questionId] || 1;
    return Math.round(((raw - 1) / 3) * 100);
  }

  function getMaturityLevel(score: number): string {
    if (score <= 35) return 'exploring';
    if (score <= 55) return 'experimenting';
    if (score <= 75) return 'operationalizing';
    return 'transforming';
  }

  // =========================================================================
  // Radar Chart (inline SVG)
  // =========================================================================
  function drawRadarChart(scores: { label: string; value: number }[]) {
    const svg = document.getElementById('radar-chart');
    if (!svg) return;

    const cx = 200;
    const cy = 200;
    const maxR = 150;
    const n = scores.length;
    const angleStep = (2 * Math.PI) / n;
    const startAngle = -Math.PI / 2; // Start from top

    // Grid levels
    const levels = [25, 50, 75, 100];
    let svgContent = '';

    // Background grid
    levels.forEach((level) => {
      const r = (level / 100) * maxR;
      const points = [];
      for (let i = 0; i < n; i++) {
        const angle = startAngle + i * angleStep;
        points.push(`${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}`);
      }
      svgContent += `<polygon points="${points.join(' ')}" fill="none" stroke="#E2E8F0" stroke-width="1" />`;
    });

    // Axis lines
    for (let i = 0; i < n; i++) {
      const angle = startAngle + i * angleStep;
      const x = cx + maxR * Math.cos(angle);
      const y = cy + maxR * Math.sin(angle);
      svgContent += `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="#E2E8F0" stroke-width="1" />`;
    }

    // Data polygon
    const dataPoints = [];
    scores.forEach((s, i) => {
      const angle = startAngle + i * angleStep;
      const r = (s.value / 100) * maxR;
      dataPoints.push(`${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}`);
    });
    svgContent += `<polygon points="${dataPoints.join(' ')}" fill="rgba(14, 165, 160, 0.15)" stroke="#0EA5A0" stroke-width="2.5" />`;

    // Data points (circles)
    scores.forEach((s, i) => {
      const angle = startAngle + i * angleStep;
      const r = (s.value / 100) * maxR;
      const x = cx + r * Math.cos(angle);
      const y = cy + r * Math.sin(angle);
      svgContent += `<circle cx="${x}" cy="${y}" r="4" fill="#0EA5A0" stroke="#fff" stroke-width="2" />`;
    });

    // Labels
    scores.forEach((s, i) => {
      const angle = startAngle + i * angleStep;
      const labelR = maxR + 28;
      const x = cx + labelR * Math.cos(angle);
      const y = cy + labelR * Math.sin(angle);
      const anchor = Math.abs(Math.cos(angle)) < 0.1 ? 'middle' : Math.cos(angle) > 0 ? 'start' : 'end';
      const dy = Math.sin(angle) > 0.3 ? '1em' : Math.sin(angle) < -0.3 ? '-0.3em' : '0.35em';
      svgContent += `<text x="${x}" y="${y}" text-anchor="${anchor}" dy="${dy}" class="text-xs" fill="#4A5568" font-size="11" font-weight="600" font-family="Inter, sans-serif">${s.label}</text>`;
      svgContent += `<text x="${x}" y="${y}" text-anchor="${anchor}" dy="${parseFloat(dy as string) + 1.2}em" fill="#0EA5A0" font-size="11" font-weight="700" font-family="Inter, sans-serif">${s.value}</text>`;
    });

    svg.innerHTML = svgContent;
  }

  // =========================================================================
  // Results Generation
  // =========================================================================
  function generateResults() {
    const companyName = (document.getElementById('company-name') as HTMLInputElement)?.value || 'Your Company';
    const industry = (document.getElementById('industry') as HTMLSelectElement)?.value || 'Other';
    const score = calculateScore();
    const maturityKey = getMaturityLevel(score);
    const maturity = MATURITY_LEVELS[maturityKey as keyof typeof MATURITY_LEVELS];

    // Populate score
    const scoreEl = document.getElementById('results-score');
    if (scoreEl) scoreEl.textContent = String(score);

    const companyEl = document.getElementById('results-company-name');
    if (companyEl) companyEl.textContent = companyName;

    // Tier badge
    const badge = document.getElementById('results-tier-badge');
    if (badge) {
      badge.textContent = maturity.label;
      badge.className = `mt-3 px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${maturity.badgeColor}`;
    }

    // Maturity description
    const matEl = document.getElementById('results-maturity');
    if (matEl) matEl.textContent = maturity.label;
    const matDesc = document.getElementById('results-maturity-desc');
    if (matDesc) matDesc.textContent = maturity.desc;

    // Radar chart
    const radarScores = QUESTIONS.map((q) => ({
      label: q.label,
      value: getDimensionScore(q.id),
    }));
    drawRadarChart(radarScores);

    // Key Insights — pick the 3 weakest dimensions
    const sortedDimensions = QUESTIONS.map((q) => ({
      id: q.id,
      score: answers[q.id] || 1,
    })).sort((a, b) => a.score - b.score);

    const insightsContainer = document.getElementById('insights-container');
    if (insightsContainer) {
      insightsContainer.innerHTML = '';
      const topInsights = sortedDimensions.slice(0, 3);
      topInsights.forEach((dim) => {
        const templates = INSIGHT_TEMPLATES[dim.id as keyof typeof INSIGHT_TEMPLATES];
        if (!templates) return;
        const template = templates.find((t) => t.threshold === dim.score) || templates[0];
        insightsContainer.innerHTML += `
          <div class="insight-card pl-5 py-4 pr-4 bg-white rounded-r-lg">
            <h4 class="text-sm font-bold text-navy mb-1">${template.title}</h4>
            <p class="text-sm text-slate leading-relaxed">${template.text}</p>
          </div>
        `;
      });
    }

    // Benchmarks
    const bmKey = industry in INDUSTRY_BENCHMARKS ? industry : 'Other';
    const bmSet = INDUSTRY_BENCHMARKS[bmKey as keyof typeof INDUSTRY_BENCHMARKS];
    const bmMaturity = bmSet[maturityKey as keyof typeof bmSet] || bmSet.exploring;

    const bmIntro = document.getElementById('benchmark-intro');
    if (bmIntro) {
      bmIntro.textContent = `Companies in ${bmKey === 'Other' ? 'your industry' : bmKey} at the ${maturity.label} stage typically face these benchmarks:`;
    }

    const bmItems = document.getElementById('benchmark-items');
    if (bmItems) {
      bmItems.innerHTML = '';
      bmMaturity.forEach((bm: string) => {
        bmItems.innerHTML += `
          <div class="flex items-start gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-teal flex-shrink-0"></span>
            <p class="text-sm text-slate">${bm}</p>
          </div>
        `;
      });
    }
  }

  // =========================================================================
  // Animated score counter
  // =========================================================================
  function animateScore(target: number) {
    const el = document.getElementById('results-score');
    if (!el) return;
    let current = 0;
    const duration = 1500;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      current = Math.round(eased * target);
      el!.textContent = String(current);
      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    }

    requestAnimationFrame(tick);
  }

  // =========================================================================
  // Event Handlers
  // =========================================================================
  document.addEventListener('DOMContentLoaded', () => {
    // Step 1 → Step 2
    document.getElementById('btn-to-step-2')?.addEventListener('click', () => {
      // Validate
      const name = (document.getElementById('company-name') as HTMLInputElement)?.value?.trim();
      const industry = (document.getElementById('industry') as HTMLSelectElement)?.value;
      const revenue = (document.getElementById('revenue') as HTMLSelectElement)?.value;
      const employees = (document.getElementById('employees') as HTMLSelectElement)?.value;

      if (!name || !industry || !revenue || !employees) {
        // Highlight empty fields
        ['company-name', 'industry', 'revenue', 'employees'].forEach((id) => {
          const el = document.getElementById(id) as HTMLInputElement;
          if (el && !el.value?.trim()) {
            el.style.borderColor = '#E53E3E';
            setTimeout(() => (el.style.borderColor = ''), 2000);
          }
        });
        return;
      }

      currentQuestion = 0;
      showStep(2);
      renderQuestion(0);
    });

    // Question navigation
    document.getElementById('btn-prev-q')?.addEventListener('click', () => {
      if (currentQuestion > 0) {
        currentQuestion--;
        renderQuestion(currentQuestion);
      } else {
        showStep(1);
      }
    });

    document.getElementById('btn-next-q')?.addEventListener('click', () => {
      const q = QUESTIONS[currentQuestion];
      if (!answers[q.id]) {
        // Flash the options to indicate selection required
        document.querySelectorAll('.option-card').forEach((card) => {
          (card as HTMLElement).style.borderColor = '#E53E3E';
          setTimeout(() => ((card as HTMLElement).style.borderColor = ''), 1500);
        });
        return;
      }

      if (currentQuestion < QUESTIONS.length - 1) {
        currentQuestion++;
        renderQuestion(currentQuestion);
      } else {
        // Show results
        showStep(3);

        // Simulate analysis loading
        const loadingText = document.getElementById('loading-text');
        const loadingSubtext = document.getElementById('loading-subtext');
        const loadingPhases = [
          { text: 'Analyzing your responses...', sub: 'Running diagnostic against CATALYST framework' },
          { text: 'Scoring dimensions...', sub: 'Calculating AI/ML footprint, data maturity, governance' },
          { text: 'Generating benchmarks...', sub: 'Comparing against industry peers' },
          { text: 'Preparing insights...', sub: 'Identifying key gaps and recommendations' },
        ];

        let phase = 0;
        const phaseInterval = setInterval(() => {
          phase++;
          if (phase < loadingPhases.length) {
            if (loadingText) loadingText.textContent = loadingPhases[phase].text;
            if (loadingSubtext) loadingSubtext.textContent = loadingPhases[phase].sub;
          }
        }, 700);

        setTimeout(() => {
          clearInterval(phaseInterval);
          generateResults();
          const loading = document.getElementById('results-loading');
          const content = document.getElementById('results-content');
          if (loading) loading.classList.add('hidden');
          if (content) content.classList.remove('hidden');

          // Animate score
          const score = calculateScore();
          animateScore(score);
        }, 3000);
      }
    });

    // Step 3 → Step 4
    document.getElementById('btn-to-step-4')?.addEventListener('click', () => {
      showStep(4);
    });
  });
</script>
